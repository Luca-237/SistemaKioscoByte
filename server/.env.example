# Copiar a .env y completar. NUNCA commitear el .env real.

PORT=4000

# MongoDB Atlas (cluster M0). Si se deja vacío en desarrollo,
# se levanta una base en memoria (mongodb-memory-server) para poder trabajar.
MONGODB_URI=

# Secreto para los JWT de operarios.
# Generar con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambiar_por_un_secreto_largo_y_aleatorio

# Clerk (auth del propietario). Pegar la Secret Key (sk_test_... / sk_live_...)
CLERK_SECRET_KEY=

# Orígenes permitidos para CORS (separados por coma)
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
